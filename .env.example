# Copy to .env for local development.
# ---------------------------------------------------------------------------
# Address the app binds to (plain HTTP; TLS is terminated by the reverse proxy).
BIND_ADDR=127.0.0.1:8080

# SQLite database file. `mode=rwc` creates it if missing.
DATABASE_URL=sqlite://data/app.db?mode=rwc

# WebAuthn relying-party configuration.
#   RP_ID     = bare host, must be a registrable suffix of RP_ORIGIN's host.
#   RP_ORIGIN = full origin URL the browser sees.
#   RP_NAME   = human-readable name shown by some authenticators.
# For local dev, localhost is treated as a secure context so WebAuthn works over http.
RP_ID=localhost
RP_ORIGIN=http://localhost:8080
RP_NAME="Firefox Enterprise"

# Bearer token guarding GET /api/export. Use a long random value in production.
EXPORT_TOKEN=dev-export-token-change-me

# Set the session cookie's Secure flag. false for local http, true behind the TLS proxy.
SESSION_SECURE=false

# tracing/log filter.
RUST_LOG=info,tower_http=info
